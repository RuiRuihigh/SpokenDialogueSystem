# Database
POSTGRES_DB=spoken_dialogue
POSTGRES_USER=spoken
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://spoken:change-me@db:5432/spoken_dialogue

# Cache
REDIS_URL=redis://redis:6379/0

# Storage paths inside the backend container
DATASET_ROOT=/dataset/spokendialoguesum
UPLOAD_ROOT=/uploads

# Upload policy
MAX_UPLOAD_SIZE_MB=100
ALLOWED_AUDIO_TYPES=audio/wav,audio/mpeg,audio/mp4,audio/ogg

# Authentication
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Optional: automatic diarized transcription for private uploads.
# Set this only in your local .env or deployment secret store, never commit a real key.
OPENAI_API_KEY=
OPENAI_ASR_MODEL=gpt-4o-transcribe-diarize
OPENAI_ASR_MAX_FILE_SIZE_MB=25

# Optional remote SpeechLLM endpoint. Use your private Hugging Face read token locally.
SPEECHLLM_API_BASE_URL=
SPEECHLLM_API_PATH=
SPEECHLLM_API_TOKEN=
SPEECHLLM_MODEL_ID=RuiRuihigh/qwen2audioinstruct-sft-merged
SPEECHLLM_REQUEST_MODE=json_base64
SPEECHLLM_REQUEST_TIMEOUT_SECONDS=600
SPEECHLLM_MAX_FILE_SIZE_MB=100
SPEECHLLM_MAX_NEW_TOKENS=256

# Runtime
APP_ENV=development
BACKEND_PORT=8000
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
